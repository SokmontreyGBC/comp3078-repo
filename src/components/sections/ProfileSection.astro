---
import { Github, Linkedin, Instagram, Mail } from "lucide-astro";
import links from "@/data/links.json";
import AboutBioContent from "@/components/sections/AboutBioContent.astro";

const iconClass = "w-5 h-5";
---

<div class="flex flex-col gap-10">
  <div class="space-y-5">
    <h1 class="font-serif text-[2rem] leading-none text-[#EED9B4]">
      Hi, I&apos;m Sokmontrey
    </h1>

    {/* Bio */}
    <div class="space-y-4">
      <AboutBioContent />
      <p class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-[#8f99a6]">
        <a
          href="/resume.pdf"
          class="text-[#c3b493] underline underline-offset-2 hover:text-[#f0e5cf] transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Resume (PDF)
        </a>
        <a
          href="/cover-letter.pdf"
          class="text-[#c3b493] underline underline-offset-2 hover:text-[#f0e5cf] transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Cover letter (PDF)
        </a>
      </p>
    </div>

    {/* Links */}
    <div class="flex gap-7">
      {
        links
          .filter((link) => link.isVisible)
          .map((link) => (
            <a
              href={link.url || "#"}
              class="text-[#A59F97] hover:text-[#f0e5cf] transition-colors"
              aria-label={link.name}
            >
              {link.name === "GitHub" && <Github class={iconClass} />}
              {link.name === "LinkedIn" && <Linkedin class={iconClass} />}
              {link.name === "Instagram" && <Instagram class={iconClass} />}
              {link.name === "Mail" && <Mail class={iconClass} />}
            </a>
          ))
      }
    </div>
  </div>
</div>
