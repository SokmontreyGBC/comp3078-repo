---
import { getAllExperiences } from '@/lib/content';

const experiences = await getAllExperiences();
const leaderDots = '. '.repeat(600).trim();
const leaderArrows = '> '.repeat(600).trim();
---

<div class="space-y-7">
	<header class="flex items-end gap-3">
		<h2 class="font-sans text-sm font-medium tracking-widest uppercase text-[#EED9B4]">Experience</h2>
		<a href="/experiences" class="leader-link font-mono text-xs text-[#A59F97] hover:text-[#d6c6a5] transition-colors flex-1 min-w-0 flex items-end gap-2 cursor-pointer">
			<span aria-hidden="true" class="leader-switch">
				<span class="leader-dots">{leaderDots}</span>
				<span class="leader-arrows">{leaderArrows}</span>
			</span>
			<span class="shrink-0">see all experiences</span>
		</a>
	</header>

	<div class="space-y-5">
		{experiences.slice(0, 3).map((experience) => (
			<article class="space-y-2 group">
				<div class="flex items-baseline justify-between gap-3 flex-wrap">
					<h3 class="font-serif text-[1.45rem] leading-none text-[#EED9B4] group-hover:text-[#F5E8C4] transition-colors">
						<a href={`/experiences/${experience.slug}`}>{experience.data.title}</a>
					</h3>
					<p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[#7f8893]">
						{experience.data.startDate.getFullYear()}
					</p>
				</div>

				<p class="font-mono text-xs uppercase tracking-wide text-[#baa67f]">
					{experience.data.company}
				</p>

				<p class="font-sans text-[15px] leading-snug text-[#A59F97] text-justify">
					{experience.data.description.split('\n')[0]}
				</p>
			</article>
		))}
	</div>
</div>

<style>
	.leader-switch {
		position: relative;
		flex: 1 1 auto;
		min-width: 0;
		overflow: hidden;
		height: 1em;
		font-family: 'EB Garamond', serif;
		font-size: 1.05rem;
		line-height: 1;
		color: rgb(107 101 87 / 0.9);
	}

	.leader-switch > span {
		position: absolute;
		inset: 0;
		white-space: nowrap;
		transition: opacity 180ms ease;
	}

	.leader-arrows {
		opacity: 0;
	}

	.leader-link:hover .leader-dots {
		opacity: 0;
	}

	.leader-link:hover .leader-arrows {
		opacity: 1;
	}
</style>
