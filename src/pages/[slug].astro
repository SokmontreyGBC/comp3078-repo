---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ChevronLeft, ExternalLink } from 'lucide-astro';
import { capstoneDocSections, capstoneProject } from '@/data/capstone';

export function getStaticPaths() {
	return [
		{
			params: { slug: capstoneProject.slug },
		},
	];
}

const { slug } = Astro.params;

if (slug !== capstoneProject.slug) {
	return Astro.redirect('/');
}
---

<BaseLayout title={`${capstoneProject.title} | sokmontrey.me`}>
	<a href="/" class="fixed top-5 left-6 font-sans text-base text-[#A59F97] hover:text-[#EED9B4] transition-colors opacity-50 hover:opacity-100">Sokmontrey</a>
	<main class="mx-auto max-w-4xl px-8 py-16 lg:px-12 lg:py-24">
		<a
			href="/"
			class="mb-8 inline-flex items-center gap-1.5 text-sm text-[#c3b493] hover:text-[#f0e5cf] transition-colors"
		>
			<ChevronLeft class="h-4 w-4" />
			<span>Back to home</span>
		</a>

		<header class="space-y-4">
			<p class="font-mono text-xs text-[#A59F97] uppercase tracking-wide">{capstoneProject.meta.join(' / ')}</p>
			<h1 class="font-serif text-[2.35rem] leading-none text-[#EED9B4]">{capstoneProject.title}</h1>
			<p class="font-mono text-xs text-[#baa67f] uppercase tracking-wide">{capstoneProject.status}</p>
		</header>

		<div class="mt-8 space-y-5 text-[15px] leading-relaxed text-[#A59F97]">
			<p class="text-justify">{capstoneProject.description}</p>
			<p class="text-justify">{capstoneProject.details}</p>
			<p class="text-justify">
				The portfolio assignment explicitly asks for capstone project artifacts such as the project summary, project vision,
				project and business requirements, project plan, requirements analysis and design, wireframes or mockups, status reports,
				and system implementation evidence. This page packages those materials into one navigable location.
			</p>
		</div>

		<section class="mt-10 grid gap-4 md:grid-cols-2">
			{capstoneProject.highlights.map((item) => (
				<div class="rounded-sm bg-[#131920] p-4 text-sm leading-relaxed text-[#C1B7A6]">
					{item}
				</div>
			))}
		</section>

		<section class="mt-12 space-y-4">
			<h2 class="font-serif text-[1.6rem] text-[#EED9B4]">Current Status</h2>
			<p class="text-[15px] leading-relaxed text-[#A59F97] text-justify">
				The current documentation shows the project moving from planning and analysis into implementation. The status report marks
				overall health as green and lists create event, share feature, database design, and database creation as completed, while
				real-time collaboration is identified as the next major objective.
			</p>
			<p class="text-[15px] leading-relaxed text-[#8f99a6] text-justify">
				{capstoneProject.nextSteps}
			</p>
		</section>

		<section class="mt-12 space-y-8">
			<h2 class="font-serif text-[1.6rem] text-[#EED9B4]">Assignment Artifacts</h2>

			{capstoneDocSections.map((section) => (
				<div class="space-y-4">
					<h3 class="font-serif text-[1.25rem] text-[#EED9B4]">{section.title}</h3>
					<div class="grid gap-4 md:grid-cols-2">
						{section.links.map((link) => (
							<a
								href={link.href}
								target="_blank"
								rel="noopener noreferrer"
								class="rounded-sm bg-[#131920] p-4 transition-colors hover:bg-[#161d25]"
							>
								<div class="flex items-start justify-between gap-3">
									<div class="space-y-2">
										<p class="font-serif text-[1.15rem] leading-tight text-[#EED9B4]">{link.label}</p>
										<p class="text-sm leading-relaxed text-[#A59F97]">{link.description}</p>
									</div>
									<ExternalLink class="h-4 w-4 shrink-0 text-[#8f99a6]" />
								</div>
							</a>
						))}
					</div>
				</div>
			))}
		</section>
	</main>
</BaseLayout>
