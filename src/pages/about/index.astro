---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutBioContent from "@/components/sections/AboutBioContent.astro";
import { ChevronLeft } from "lucide-astro";
---

<BaseLayout title="About | sokmontrey.me">
  <main class="mx-auto max-w-3xl px-8 py-16 lg:px-12 lg:py-24">
    <a
      href="/"
      class="mb-6 inline-flex items-center gap-1.5 text-sm text-[#c3b493] hover:text-[#f0e5cf] transition-colors"
      aria-label="Back to home"
    >
      <ChevronLeft class="h-4 w-4" />
      <span>Back</span>
    </a>

    <h1 class="font-serif text-[2rem] leading-none text-[#EED9B4]">
      Hi, I&apos;m Sokmontrey
    </h1>

    <div class="mt-6">
      <AboutBioContent />
    </div>
  </main>
</BaseLayout>
